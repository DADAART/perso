---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { SITE } from "../../data/site";
import { breadcrumbSchema } from "../../lib/schema";
const base = Astro.site!;
const title = `Outils e-commerce gratuits — conversion, marge, CAC, ROAS | ${SITE.name}`;
const description = "Des calculateurs gratuits pour piloter votre e-commerce : croissance, marge nette réelle, objectif de CA, rentabilité de l'acquisition, ROAS, paniers abandonnés, et un diagnostic.";
const schemas = [
  breadcrumbSchema([
    { name: "Accueil", url: base.origin + "/" },
    { name: "Outils", url: base.origin + "/outils/" },
  ]),
];
const tools = [
  { href: "/outils/diagnostic-boutique/", tag: "Diagnostic", bar: "bar-gold", c: "c-gold", h: "Diagnostic e-commerce", p: "10 questions pour évaluer la maturité de votre boutique et obtenir vos priorités." },
  { href: "/outils/calculateur-croissance/", tag: "Croissance", bar: "bar-vine", c: "c-vine", h: "Calculateur de croissance", p: "Combien votre boutique peut générer en plus, à trafic constant." },
  { href: "/outils/marge-nette-ecommerce/", tag: "Rentabilité", bar: "bar-vine", c: "c-vine", h: "Marge nette réelle", p: "Ce qu'il vous reste vraiment sur chaque commande, tous coûts déduits." },
  { href: "/outils/simulateur-objectif-ca/", tag: "Pilotage", bar: "bar-gold", c: "c-gold", h: "Simulateur d'objectif de CA", p: "Le trafic et la conversion nécessaires pour atteindre votre objectif." },
  { href: "/outils/calculateur-cac-ltv/", tag: "Acquisition", bar: "bar-river", c: "c-river", h: "Calculateur CAC / LTV", p: "Votre acquisition est-elle rentable ? Valeur client vs coût d'acquisition." },
  { href: "/outils/seuil-rentabilite-roas/", tag: "Publicité", bar: "bar-river", c: "c-river", h: "ROAS d'équilibre", p: "À partir de quel ROAS votre publicité devient rentable, selon votre marge." },
  { href: "/outils/cout-paniers-abandonnes/", tag: "Conversion", bar: "bar-river", c: "c-river", h: "Coût des paniers abandonnés", p: "Ce que les paniers abandonnés vous coûtent par an — et ce qu'une relance récupère." },
];
---
<BaseLayout title={title} description={description} schemas={schemas}>
  <section class="page-hero">
    <div class="wrap page-hero__inner">
      <span class="eyebrow">Outils</span>
      <h1>Des outils gratuits pour piloter votre e-commerce.</h1>
      <p>Des calculateurs concrets, sans inscription : entrez vos chiffres, obtenez une réponse claire. À utiliser autant de fois que vous voulez.</p>
    </div>
  </section>
  <section class="section">
    <div class="wrap">
      <div class="seg__grid">
        {tools.map((t) => (
          <a href={t.href} class={`seg__card ${t.bar} reveal`}>
            <span class={`seg__tag ${t.c}`}>{t.tag}</span>
            <h3>{t.h}</h3>
            <p>{t.p}</p>
            <span class={`seg__link ${t.c}`}>Ouvrir l'outil <span class="arr">→</span></span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
