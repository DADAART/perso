---
import { SITE, NAP, PLACEHOLDERS } from "../data/site";
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="wrap footer__top">
    <div>
      <span class="brand__name">{SITE.name}</span>
      <p class="footer__tag">{SITE.tagline}</p>
    </div>
    <div>
      <h4>Naviguer</h4>
      <ul>
        <li><a href="/#pour-qui">Pour qui</a></li>
        <li><a href="/#methode">Méthode</a></li>
        <li><a href="/#offres">Offres</a></li>
        <li><a href="/#apropos">À propos</a></li>
        <li><a href="/outils">Outils</a></li>
        <li><a href="/blog">Blog</a></li>
      </ul>
    </div>
    <div>
      <h4>Contact</h4>
      <ul>
        <li><a href={`mailto:${NAP.email}`}>{NAP.email}</a></li>
        <li><a href={`tel:${NAP.phoneE164}`}>{NAP.phoneDisplay}</a></li>
        <li><a href="/#contact">Audit gratuit</a></li>
        <li>À distance, partout en France</li>
        <li><a href={SITE.social.linkedin} rel="noopener" target="_blank" aria-label="LinkedIn">LinkedIn</a></li>
      </ul>
    </div>
  </div>
  <div class="wrap footer__bottom">
    <span>© {year} {SITE.name} — {NAP.founder}</span>
    <span>
      Micro-entreprise · {PLACEHOLDERS.SIRET === "SIRET_A_COMPLETER" ? "immatriculation en cours" : `SIRET ${PLACEHOLDERS.SIRET}`} ·
      <a href="/mentions-legales">Mentions légales</a> ·
      <a href="/politique-confidentialite">Confidentialité</a> ·
      <a href="#tarteaucitron" id="tarteaucitronManager">Gérer les cookies</a>
    </span>
  </div>
</footer>
