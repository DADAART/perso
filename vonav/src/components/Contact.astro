---
/**
 * Section Contact — formulaire branché sur Web3Forms (gratuit, sans compte hébergé).
 * La clé d'accès est dans PLACEHOLDERS.FORM_BACKEND_ID : voir ETAPES-MANUELLES.md.
 */
import { PLACEHOLDERS, NAP, SITE } from "../data/site";
---
<section class="section contact" id="contact">
  <div class="wrap contact__grid">
    <div class="reveal">
      <span class="eyebrow">On en parle ?</span>
      <h2>Recevez votre audit e-commerce gratuit.</h2>
      <p class="contact__sub">Dites-moi qui vous êtes et où vous en êtes. Je vous réponds sous 48 h avec un premier regard concret sur votre e-commerce.</p>
      <div class="contact__reassure">
        <span>Sans engagement</span>
        <span>Réponse sous 48 h</span>
        <span>Vos informations restent confidentielles</span>
      </div>
      {PLACEHOLDERS.BOOKING_URL && (
        <a class="btn btn--ghost" style="margin-top:1.6rem" href={PLACEHOLDERS.BOOKING_URL} target="_blank" rel="noopener">
          Ou réservez directement 30 min <span class="arr">→</span>
        </a>
      )}
    </div>
    <div class="reveal">
      <form id="contactForm" action="https://api.web3forms.com/submit" method="POST" novalidate>
        <input type="hidden" name="access_key" value={PLACEHOLDERS.FORM_BACKEND_ID} />
        <input type="hidden" name="subject" value={`Nouvelle demande — ${SITE.name}`} />
        <input type="hidden" name="from_name" value={`Site ${SITE.name}`} />
        <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" style="display:none" aria-hidden="true" />

        <div class="field row">
          <div class="field"><label for="nom">Prénom &amp; nom</label><input id="nom" name="nom" type="text" placeholder="Camille Dupont" required /></div>
          <div class="field"><label for="email">Email</label><input id="email" name="email" type="email" placeholder="vous@domaine.fr" required /></div>
        </div>
        <div class="field row">
          <div class="field"><label for="tel">Téléphone <span style="text-transform:none;letter-spacing:0">(facultatif)</span></label><input id="tel" name="tel" type="tel" placeholder="06 00 00 00 00" /></div>
          <div class="field"><label for="profil">Votre situation</label>
            <select id="profil" name="profil" required>
              <option value="" selected disabled>Choisir…</option>
              <option>Je vends déjà en ligne</option>
              <option>Je lance / refonds ma boutique</option>
              <option>Je cherche une direction e-commerce</option>
              <option>Autre</option>
            </select>
          </div>
        </div>
        <div class="field row">
          <div class="field"><label for="site">Votre site actuel <span style="text-transform:none;letter-spacing:0">(facultatif)</span></label><input id="site" name="site" type="text" placeholder="https://…" /></div>
          <div class="field"><label for="ca">Votre CA annuel en ligne</label>
            <select id="ca" name="ca_annuel" required>
              <option value="" selected disabled>Choisir…</option>
              <option>Je lance mon activité</option>
              <option>Moins de 300 k€</option>
              <option>300 k€ – 1 M€</option>
              <option>1 M€ – 10 M€</option>
              <option>Plus de 10 M€</option>
            </select>
          </div>
        </div>
        <div class="field"><label for="message">En deux mots, votre objectif</label><textarea id="message" name="message" placeholder="Augmenter mes ventes, refondre ma boutique, structurer mon e-commerce…"></textarea></div>

        <div class="hp-field" aria-hidden="true">
          <label for="website_hp">Ne pas remplir</label>
          <input id="website_hp" name="website_hp" type="text" tabindex="-1" autocomplete="off" />
        </div>

        <button type="submit" class="btn btn--primary">Recevoir mon audit <span class="arr">→</span></button>
        <p class="form-error" id="formError" role="alert"></p>
      </form>
      <div class="form-success" id="formSuccess" role="status" tabindex="-1">
        <strong>Merci !</strong> Votre demande est bien notée — je vous réponds sous 48 h avec un premier regard sur votre e-commerce.
      </div>
    </div>
  </div>
</section>

<script define:vars={{ contactEmail: NAP.email }}>
  const form = document.getElementById("contactForm");
  const success = document.getElementById("formSuccess");
  const errorBox = document.getElementById("formError");
  if (form) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      errorBox.classList.remove("show");
      const hp = form.querySelector('[name="website_hp"]');
      if (hp && hp.value) return;
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }
      const btn = form.querySelector('button[type="submit"]');
      const original = btn.innerHTML;
      btn.disabled = true;
      btn.textContent = "Envoi…";
      try {
        const res = await fetch(form.action, {
          method: "POST",
          body: new FormData(form),
          headers: { Accept: "application/json" },
        });
        const json = await res.json().catch(() => ({}));
        if (res.ok && json.success) {
          form.style.display = "none";
          success.classList.add("show");
          if (success.focus) success.focus();
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({ event: "generate_lead", form: "contact" });
        } else {
          throw new Error(json.message || "Échec de l'envoi");
        }
      } catch (err) {
        btn.disabled = false;
        btn.innerHTML = original;
        errorBox.textContent =
          "Une erreur s'est produite. Écrivez-moi directement à " +
          contactEmail +
          " ou réessayez dans un instant.";
        errorBox.classList.add("show");
      }
    });
  }
</script>
