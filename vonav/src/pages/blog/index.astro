---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { SITE } from "../../data/site";
import { breadcrumbSchema } from "../../lib/schema";
import { Image } from "astro:assets";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const fmt = (d: Date) =>
  new Intl.DateTimeFormat("fr-FR", { day: "numeric", month: "long", year: "numeric" }).format(d);

const base = Astro.site!;
const title = `Blog e-commerce : conversion, acquisition & Shopify | ${SITE.name}`;
const description =
  "Des guides concrets pour vendre plus en ligne : taux de conversion (CRO), acquisition rentable, Shopify, fidélisation et pilotage. À appliquer, pas à théoriser.";

const schemas = [
  breadcrumbSchema([
    { name: "Accueil", url: base.origin + "/" },
    { name: "Blog", url: base.origin + "/blog/" },
  ]),
];
---
<BaseLayout title={title} description={description} schemas={schemas}>
  <section class="page-hero">
    <div class="wrap page-hero__inner">
      <span class="eyebrow">Le blog</span>
      <h1>Vendre plus en ligne, sans jargon.</h1>
      <p>Des guides concrets pour les marques et les e-commerçants : taux de conversion (CRO), acquisition rentable, Shopify, fidélisation et pilotage. À appliquer, pas à théoriser.</p>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      {posts.length === 0 ? (
        <p class="lead">Les premiers articles arrivent très bientôt.</p>
      ) : (
        <div class="bloglist">
          {posts.map((post) => (
            <article class="postcard">
              {post.data.heroImage && (
                <a href={`/blog/${post.id}/`} tabindex="-1" aria-hidden="true">
                  <Image src={post.data.heroImage} alt={post.data.heroImageAlt ?? ""} class="postcard__thumb" widths={[400, 640]} sizes="(max-width: 720px) 92vw, 360px" loading="lazy" />
                </a>
              )}
              <span class="postcard__meta">{fmt(post.data.pubDate)}</span>
              <h2><a href={`/blog/${post.id}/`}>{post.data.title}</a></h2>
              <p>{post.data.description}</p>
              {post.data.tags.length > 0 && (
                <div class="tags">{post.data.tags.slice(0, 3).map((t) => <span class="tag">{t}</span>)}</div>
              )}
              <a class="postcard__link" href={`/blog/${post.id}/`}>Lire l'article <span class="arr">→</span></a>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
