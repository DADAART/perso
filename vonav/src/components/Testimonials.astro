---
/**
 * Témoignages — EXEMPLES explicitement étiquetés (aucun faux avis).
 * À remplacer par de vrais témoignages clients dès qu'ils existent,
 * ou masquer la section (commenter <Testimonials /> dans index.astro).
 */
import { SITE } from "../data/site";

const examples = [
  {
    quote:
      "On avait du trafic mais ça ne convertissait pas. En quelques mois, le taux de conversion a vraiment bougé.",
    who: "Marque DTC · mode",
  },
  {
    quote:
      "Enfin un interlocuteur unique qui pilote nos prestataires et parle résultats. On a arrêté de naviguer à vue.",
    who: "E-commerçant · équipement sport",
  },
  {
    quote:
      "La refonte Shopify a payé dès le lancement : tunnel plus court, fiches plus claires, plus de ventes.",
    who: "Marque · cosmétique",
  },
];
---
<section class="section testi">
  <div class="wrap">
    <span class="eyebrow reveal">Ils en parlent</span>
    <h2 class="reveal">Bientôt, leurs résultats — peut-être les vôtres.</h2>
    <p class="testi__intro reveal">{SITE.name} démarre : ces retours sont des exemples du type de résultats visés. Ils seront remplacés par les avis de vos premiers clients.</p>
    <div class="testi__grid">
      {/* TODO : remplacer par de vrais témoignages clients. Ne pas publier de faux avis. */}
      {examples.map((t) => (
        <figure class="testi__card reveal">
          <span class="testi__ex">Exemple</span>
          <p>« {t.quote} »</p>
          <figcaption class="testi__who">{t.who}</figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
