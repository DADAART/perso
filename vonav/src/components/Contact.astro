---
/**
 * Section Contact — formulaire branché sur Web3Forms (gratuit, sans compte hébergé).
 * La clé d'accès est un PLACEHOLDER (FORM_BACKEND_ID) : voir ETAPES-MANUELLES.md.
 * Notification reçue sur l'e-mail associé à la clé (bonjour@vonav.com).
 */
import { PLACEHOLDERS, NAP, SITE } from "../data/site";
---
<section class="section contact" id="contact">
  <div class="wrap contact__grid">
    <div class="reveal">
      <span class="eyebrow">On en parle ?</span>
      <h2>Recevez votre diagnostic gratuit.</h2>
      <p class="contact__sub">Dites-moi qui vous êtes et où vous en êtes. Je vous réponds sous 48 h avec un premier regard concret.</p>
      <div class="contact__reassure">
        <span>Sans engagement</span>
        <span>Réponse sous 48 h</span>
        <span>Vos informations restent confidentielles</span>
      </div>
    </div>
    <div class="reveal">
      <form id="contactForm" action="https://api.web3forms.com/submit" method="POST" novalidate>
        <!-- Web3Forms : configuration -->
        <input type="hidden" name="access_key" value={PLACEHOLDERS.FORM_BACKEND_ID} />
        <input type="hidden" name="subject" value={`Nouvelle demande de diagnostic — ${SITE.name}`} />
        <input type="hidden" name="from_name" value={`Site ${SITE.name}`} />
        <!-- Honeypot natif Web3Forms (rempli => spam) -->
        <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" style="display:none" aria-hidden="true" />

        <div class="field row">
          <div class="field"><label for="nom">Prénom &amp; nom</label><input id="nom" name="nom" type="text" placeholder="Camille Dupont" required /></div>
          <div class="field"><label for="email">Email</label><input id="email" name="email" type="email" placeholder="vous@domaine.fr" required /></div>
        </div>
        <div class="field row">
          <div class="field"><label for="tel">Téléphone <span style="text-transform:none;letter-spacing:0">(facultatif)</span></label><input id="tel" name="tel" type="tel" placeholder="06 00 00 00 00" /></div>
          <div class="field"><label for="profil">Vous êtes</label>
            <select id="profil" name="profil" required>
              <option value="" selected disabled>Choisir…</option>
              <option>Vigneron / domaine</option>
              <option>Gîte / chambres d'hôtes</option>
              <option>Restaurant / producteur</option>
              <option>Cave / groupe / destination</option>
              <option>Autre</option>
            </select>
          </div>
        </div>
        <div class="field"><label for="site">Votre site actuel <span style="text-transform:none;letter-spacing:0">(facultatif)</span></label><input id="site" name="site" type="text" placeholder="https://…" /></div>
        <div class="field"><label for="message">En deux mots, votre objectif</label><textarea id="message" name="message" placeholder="Vendre plus en direct, remplir hors saison, refaire mon site…"></textarea></div>

        <!-- Honeypot anti-spam supplémentaire (invisible, vérifié côté client) -->
        <div class="hp-field" aria-hidden="true">
          <label for="website_hp">Ne pas remplir</label>
          <input id="website_hp" name="website_hp" type="text" tabindex="-1" autocomplete="off" />
        </div>

        <button type="submit" class="btn btn--primary">Recevoir mon diagnostic <span class="arr">→</span></button>
        <p class="form-error" id="formError" role="alert"></p>
      </form>
      <div class="form-success" id="formSuccess" role="status" tabindex="-1">
        <strong>Merci !</strong> Votre demande est bien notée — je vous réponds sous 48 h avec un premier regard sur votre présence en ligne.
      </div>
    </div>
  </div>
</section>

<script define:vars={{ contactEmail: NAP.email }}>
  const form = document.getElementById("contactForm");
  const success = document.getElementById("formSuccess");
  const errorBox = document.getElementById("formError");
  if (form) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      errorBox.classList.remove("show");
      // Honeypot : si rempli, on ignore silencieusement (bot)
      const hp = form.querySelector('[name="website_hp"]');
      if (hp && hp.value) return;
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }
      const btn = form.querySelector('button[type="submit"]');
      const original = btn.innerHTML;
      btn.disabled = true;
      btn.textContent = "Envoi…";
      try {
        const res = await fetch(form.action, {
          method: "POST",
          body: new FormData(form),
          headers: { Accept: "application/json" },
        });
        const json = await res.json().catch(() => ({}));
        if (res.ok && json.success) {
          form.style.display = "none";
          success.classList.add("show");
          if (success.focus) success.focus();
        } else {
          throw new Error(json.message || "Échec de l'envoi");
        }
      } catch (err) {
        btn.disabled = false;
        btn.innerHTML = original;
        errorBox.textContent =
          "Une erreur s'est produite. Écrivez-moi directement à " +
          contactEmail +
          " ou réessayez dans un instant.";
        errorBox.classList.add("show");
      }
    });
  }
</script>
