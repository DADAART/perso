---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ToolLeadForm from "../../components/ToolLeadForm.astro";
import { breadcrumbSchema } from "../../lib/schema";
import "../../styles/tools.css";
const base = Astro.site!;
const url = base.origin + "/outils/calculateur-cac-ltv/";
const title = "Calculateur CAC / LTV : votre acquisition est-elle rentable ? | VONAV";
const description = "Calculez la valeur vie client (LTV) et le ratio LTV/CAC de votre boutique, et le coût d'acquisition maximum à ne pas dépasser pour rester rentable.";
const schemas = [
  breadcrumbSchema([
    { name: "Accueil", url: base.origin + "/" },
    { name: "Outils", url: base.origin + "/outils/" },
    { name: "Calculateur CAC / LTV", url },
  ]),
  { "@context": "https://schema.org", "@type": "WebApplication", name: "Calculateur CAC / LTV", url, applicationCategory: "BusinessApplication", operatingSystem: "Web", offers: { "@type": "Offer", price: "0", priceCurrency: "EUR" }, description, provider: { "@type": "Organization", name: "VONAV", url: base.origin + "/" } },
];
---
<BaseLayout title={title} description={description} schemas={schemas}>
  <section class="vn-host">
    <div class="vn-wrap">
      <header>
        <p class="vn-eyebrow">VONAV · Outil gratuit</p>
        <h1>Votre acquisition est-elle rentable ?</h1>
        <p class="vn-sub">Comparez ce qu'un client vous rapporte (LTV) à ce qu'il vous coûte (CAC). Le ratio sain tourne autour de 3 pour 1.</p>
      </header>
      <div class="vn-calc">
        <section class="vn-card" aria-label="Vos paramètres">
          <h2>Vos chiffres</h2>
          <p class="vn-hint">Des estimations suffisent. Tout reste dans votre navigateur.</p>
          <div class="vn-field"><label for="panier">Panier moyen</label><div class="vn-input"><input id="panier" type="number" min="0" step="1" value="65" inputmode="decimal"><span class="vn-unit">€</span></div></div>
          <div class="vn-field"><label for="marge">Marge brute</label><div class="vn-input"><input id="marge" type="number" min="0" max="100" step="1" value="40" inputmode="decimal"><span class="vn-unit">%</span></div></div>
          <div class="vn-field"><label for="freq">Commandes par client / an</label><div class="vn-input"><input id="freq" type="number" min="0" step="0.1" value="1.3" inputmode="decimal"><span class="vn-unit">cmd</span></div></div>
          <div class="vn-field"><label for="duree">Durée de vie client</label><div class="vn-input"><input id="duree" type="number" min="0.5" step="0.5" value="3" inputmode="decimal"><span class="vn-unit">ans</span></div></div>
          <div class="vn-field"><label for="cac">Coût d'acquisition (CAC)</label><div class="vn-input"><input id="cac" type="number" min="0" step="1" value="25" inputmode="decimal"><span class="vn-unit">€</span></div></div>
        </section>
        <section class="vn-readout" aria-live="polite">
          <p class="vn-rk">Rentabilité de l'acquisition</p>
          <div class="vn-rrow"><span class="vn-rlab">Marge par commande</span><span class="vn-rfig" id="r-mc">—</span></div>
          <div class="vn-rrow"><span class="vn-rlab">Valeur vie client (LTV, en marge)</span><span class="vn-rfig" id="r-ltv">—</span></div>
          <div class="vn-gain">
            <p class="vn-glab">Ratio LTV / CAC</p>
            <div class="vn-gfig" id="r-ratio">—</div>
            <p class="vn-gpct" id="r-verdict">—</p>
          </div>
          <p class="vn-insight">CAC maximum conseillé (pour un ratio 3:1) : <b id="r-cacmax">—</b>. Au-delà, votre acquisition devient fragile.</p>
        </section>
      </div>
      <ToolLeadForm tool="Calculateur CAC / LTV" />
      <div class="vn-method">
        <h3>Comment ce calcul fonctionne</h3>
        <p>La LTV mesurée ici est exprimée en <strong>marge brute</strong> (ce qu'il vous reste réellement), pas en chiffre d'affaires. C'est elle qu'il faut comparer au CAC.</p>
        <span class="vn-eq">LTV = Panier × Marge × Commandes/an × Durée de vie · Ratio = LTV ÷ CAC</span>
      </div>
      <footer class="vn-foot">
        <p class="vn-credit">Outil créé par <a href="/">VONAV</a> — direction e-commerce externalisée.</p>
        <a class="vn-cta" href="/#contact">Optimiser mon acquisition <span>→</span></a>
      </footer>
    </div>
  </section>
</BaseLayout>
<script>
(function(){
  "use strict";
  var euro=new Intl.NumberFormat('fr-FR',{style:'currency',currency:'EUR',maximumFractionDigits:0});
  var $=function(id){return document.getElementById(id);};
  if(!$('panier'))return;
  var els=['panier','marge','freq','duree','cac'].map($);
  function num(el,f){var v=parseFloat(el.value);return isFinite(v)?v:f;}
  function compute(){
    var panier=Math.max(0,num(els[0],0)),marge=Math.max(0,num(els[1],0))/100,
        freq=Math.max(0,num(els[2],0)),duree=Math.max(0,num(els[3],0)),cac=Math.max(0,num(els[4],0));
    var mc=panier*marge;
    var ltv=mc*freq*duree;
    var ratio=cac>0?ltv/cac:0;
    var cacmax=ltv/3;
    $('r-mc').textContent=euro.format(mc);
    $('r-ltv').textContent=euro.format(ltv);
    $('r-ratio').textContent=(cac>0?ratio.toLocaleString('fr-FR',{minimumFractionDigits:1,maximumFractionDigits:1}):'—')+(cac>0?' : 1':'');
    $('r-cacmax').textContent=euro.format(cacmax);
    var v;
    if(cac<=0)v="Renseignez votre CAC pour obtenir le ratio.";
    else if(ratio<1)v="⚠ Vous perdez de l'argent à chaque acquisition.";
    else if(ratio<3)v="Rentable mais fragile — visez 3:1.";
    else if(ratio<=5)v="Sain : bon équilibre acquisition / valeur.";
    else v="Très sain — vous pourriez sans doute investir plus en acquisition.";
    $('r-verdict').textContent=v;
    var ctx=$('tool-context');
    if(ctx)ctx.value='Panier '+panier+'EUR | Marge '+(marge*100)+'% | Freq '+freq+'/an | Duree '+duree+'ans | CAC '+cac+'EUR | LTV(marge) '+Math.round(ltv)+' | Ratio '+(ratio?ratio.toFixed(2):'NA');
  }
  els.forEach(function(el){el.addEventListener('input',compute);});
  compute();
})();
</script>
