<a class="sticky-cta" id="stickyCta" href="/#contact" aria-hidden="true" tabindex="-1">
  <span class="sticky-cta__txt">Diagnostic gratuit, sans engagement</span>
  <span class="btn btn--primary">Demander →</span>
</a>
<script>
  const el = document.getElementById("stickyCta");
  if (el) {
    const onScroll = () => {
      if (window.scrollY > 700) {
        el.classList.add("show");
        el.removeAttribute("aria-hidden");
        el.removeAttribute("tabindex");
      } else {
        el.classList.remove("show");
        el.setAttribute("aria-hidden", "true");
        el.setAttribute("tabindex", "-1");
      }
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();
  }
</script>
