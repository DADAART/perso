---
// Ancienne page (repositionnement) — redirige vers l'accueil. Noindex.
const dest = "/";
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${dest}`} />
    <meta name="robots" content="noindex, follow" />
    <link rel="canonical" href="https://vonav.fr/" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Page déplacée — VONAV</title>
  </head>
  <body>
    <p>Cette page a été déplacée. <a href="/">Aller à l'accueil</a>.</p>
  </body>
</html>
