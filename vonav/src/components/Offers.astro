---
// Section "Les offres"
---
<section class="section offers" id="offres">
  <div class="wrap">
    <span class="eyebrow reveal">Les offres</span>
    <h2 class="reveal">Une porte d'entrée, puis on construit ensemble.</h2>
    <div class="offers__grid">
      <div class="offer reveal">
        <h3>Diagnostic Croissance</h3>
        <p class="offer__desc">Audit complet de votre présence + un plan d'action priorisé et chiffré.</p>
        <div class="offer__price">Offert</div>
      </div>
      <div class="offer reveal">
        <h3>Pack Présence</h3>
        <p class="offer__desc">Site ou boutique optimisée, fiche Google Business et bases du référencement local.</p>
        <div class="offer__price">à partir de 1 500 €</div>
      </div>
      <div class="offer offer--feature reveal">
        <span class="offer__flag">Le plus choisi</span>
        <h3>Accompagnement Croissance</h3>
        <p class="offer__desc">Référencement, publicité et contenu pilotés chaque mois. Orienté ventes et réservations directes.</p>
        <div class="offer__price">à partir de 600 € <small>/ mois</small></div>
      </div>
      <div class="offer reveal">
        <h3>Directeur marketing externalisé</h3>
        <p class="offer__desc">Pilotage stratégique de tous vos leviers, pour les structures ambitieuses.</p>
        <div class="offer__price">sur mesure</div>
      </div>
    </div>
  </div>
</section>
