---
import { SITE } from "../data/site";
---
<section class="hero" id="top">
  <!-- grain papier subtil -->
  <svg class="hero__noise" aria-hidden="true"><filter id="n"><feTurbulence type="fractalNoise" baseFrequency="0.8" numOctaves="2"></feTurbulence></filter><rect width="100%" height="100%" filter="url(#n)"></rect></svg>
  <!-- signature : terrasses de vignes / courbe de croissance -->
  <svg class="hero__terraces" viewBox="0 0 1440 420" preserveAspectRatio="none" aria-hidden="true">
    <path class="terr" d="M0,400 C300,360 560,320 760,250 C980,175 1180,150 1440,90" fill="none" stroke="rgba(213,138,30,.5)" stroke-width="1.5"></path>
    <path class="terr" d="M0,420 C320,392 580,360 800,300 C1010,243 1230,215 1440,160" fill="none" stroke="rgba(110,158,85,.5)" stroke-width="1.5"></path>
    <path class="terr" d="M0,440 C340,420 600,398 840,348 C1040,307 1260,285 1440,235" fill="none" stroke="rgba(194,106,74,.42)" stroke-width="1.5"></path>
    <path class="terr" d="M0,470 C360,452 620,438 880,398 C1080,367 1300,352 1440,312" fill="none" stroke="rgba(33,30,24,.12)" stroke-width="1.5"></path>
  </svg>
  <div class="wrap hero__inner">
    <span class="eyebrow">Studio indépendant · Valence &amp; vallée de la Drôme</span>
    <h1>Votre savoir-faire mérite d'être trouvé — <em>et de vous rapporter.</em></h1>
    <p class="hero__sub">Studio de croissance digitale pour les vignerons, hébergeurs et acteurs du tourisme de la Drôme. Je transforme votre visibilité en réservations et en ventes directes — sans intermédiaire qui rogne votre marge.</p>
    <div class="hero__cta">
      <a href="/#contact" class="btn btn--primary">Recevoir mon diagnostic gratuit <span class="arr">→</span></a>
      <a href="/#methode" class="btn btn--ghost">Voir la méthode</a>
    </div>
    <div class="hero__trust">
      <span>{SITE.experienceYears} ans d'e-commerce &amp; de growth</span>
      <span>Réponse sous 48 h</span>
      <span>Ancré en Drôme</span>
    </div>
  </div>
</section>
