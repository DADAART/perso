---
import BaseLayout from "../layouts/BaseLayout.astro";
import Method from "../components/Method.astro";
import Zones from "../components/Zones.astro";
import { serviceSchema, breadcrumbSchema } from "../lib/schema";
import { Image } from "astro:assets";
import banner from "../assets/landing/hebergeurs.jpg";

const base = Astro.site!;
const url = base.origin + "/hebergeurs/";
const title = "Réservation directe pour gîtes & chambres d'hôtes en Drôme | VONAV";
const description =
  "Site de réservation directe, photos pro et référencement local : remplissez vos hébergements en Drôme sans les commissions de Booking et Airbnb.";

const features = [
  { t: "Un site de réservation directe", d: "Moteur de réservation, paiement de l'acompte en ligne et calendrier synchronisé avec vos plateformes — fini les doubles réservations, fini les 15 à 18 % de commission." },
  { t: "Des photos professionnelles", d: "Le premier déclencheur de réservation, et de loin. On met votre lieu en valeur comme il le mérite." },
  { t: "Référencement local", d: "Apparaître sur « gîte vallée de la Drôme », « chambre d'hôtes près de l'Hermitage », « où dormir ViaRhôna » : fiche Google Business Profile + pages pensées pour ces recherches." },
  { t: "De l'occupation hors saison", d: "Cyclotouristes de la ViaRhôna, œnotourisme, télétravail au vert, longs week-ends d'arrière-saison : on va chercher les nuits que les plateformes ne vous apportent pas." },
  { t: "Récupérer les clients des plateformes", d: "Transformer un voyageur venu de Booking en client direct pour son prochain séjour — légalement, et sans y passer vos soirées." },
  { t: "Avis & fidélisation", d: "Des voyageurs qui reviennent et qui vous recommandent : la meilleure source de réservations, gratuite et durable." },
];
const schemas = [
  serviceSchema(base, {
    name: "Réservation directe pour gîtes et chambres d'hôtes",
    serviceType: "Création de site de réservation directe et référencement local pour hébergeurs",
    description,
    url,
  }),
  breadcrumbSchema([
    { name: "Accueil", url: base.origin + "/" },
    { name: "Gîtes & hébergeurs", url },
  ]),
];
---
<BaseLayout title={title} description={description} schemas={schemas} ogImage="/og/hebergeurs.jpg">
  <section class="page-hero">
    <div class="wrap page-hero__inner">
      <span class="eyebrow">Gîtes &amp; chambres d'hôtes · Drôme</span>
      <h1>Remplissez vos hébergements en direct. Sans les commissions.</h1>
      <p>Booking et Airbnb vous remplissent, mais prélèvent souvent 15 à 18 % de chaque nuitée. J'aide les gîtes et chambres d'hôtes de la Drôme à reprendre une part de réservations en direct — avec un site qui réserve tout seul, de belles photos et le bon référencement local — pour gagner plus à chiffre d'affaires égal.</p>
      <div class="hero__cta" style="margin-top:2rem">
        <a href="/#contact" class="btn btn--primary">Recevoir mon diagnostic gratuit <span class="arr">→</span></a>
        <a href="/blog/reduire-commissions-booking-airbnb/" class="btn btn--ghost">Lire le guide</a>
      </div>
    </div>
  </section>

  <div class="wrap" style="margin-top:1.4rem">
    <Image src={banner} alt="Réservation directe pour gîtes et hébergeurs en Drôme — VONAV" class="lp-banner" widths={[600, 1000, 1600]} sizes="100vw" loading="eager" />
  </div>

  <section class="section" style="--accent:var(--river)">
    <div class="wrap">
      <span class="eyebrow reveal">Le constat</span>
      <h2 class="reveal">Sur une saison, les commissions, c'est plusieurs milliers d'euros.</h2>
      <p class="lead reveal">L'idée n'est pas de quitter les plateformes — elles restent un excellent canal de découverte. C'est d'arrêter de leur confier <strong>100 %</strong> de vos réservations, et d'en récupérer une part en direct, là où la marge vous revient entièrement.</p>

      <div class="lp-features">
        {features.map((f) => (
          <div class="lp-feature">
            <h3>{f.t}</h3>
            <p>{f.d}</p>
          </div>
        ))}
      </div>

      <div class="lp-roi reveal">
        <strong>Le calcul :</strong> sur 60 nuitées par an, les commissions évitées remboursent souvent le site de réservation directe en <strong>une seule saison</strong>. Tout ce qui vient ensuite est du gagné.
      </div>
    </div>
  </section>

  <Method />

  <section class="section seg">
    <div class="wrap">
      <span class="eyebrow reveal">À lire</span>
      <h2 class="reveal">Pour aller plus loin</h2>
      <div class="seg__grid">
        <a href="/blog/reduire-commissions-booking-airbnb/" class="seg__card bar-river reveal">
          <span class="seg__tag c-river">Guide</span>
          <h3>Réduire les commissions Booking &amp; Airbnb</h3>
          <p>Le guide de la réservation en direct pour les hébergeurs.</p>
          <span class="seg__link c-river">Lire <span class="arr">→</span></span>
        </a>
        <a href="/blog/google-business-profile-domaine-gite-drome/" class="seg__card bar-gold reveal">
          <span class="seg__tag c-gold">Guide</span>
          <h3>Google Business Profile</h3>
          <p>Le pas-à-pas pour un gîte en Drôme.</p>
          <span class="seg__link c-gold">Lire <span class="arr">→</span></span>
        </a>
      </div>
    </div>
  </section>

  <Zones />

  <aside class="article__cta" style="max-width:var(--maxw);margin-inline:auto">
    <h3>Combien les commissions vous coûtent-elles vraiment ?</h3>
    <p>Je regarde vos annonces et votre présence en ligne, et je vous dis combien la réservation directe pourrait vous faire gagner. C'est gratuit et sans engagement.</p>
    <a href="/#contact" class="btn btn--primary">Recevoir mon diagnostic gratuit <span class="arr">→</span></a>
  </aside>
</BaseLayout>
